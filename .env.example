# Le Potato Audio Stack — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env

# ─── Device Identity ──────────────────────────────────────────────────────────
DEVICE_NAME=music-potato        # Name shown in AirPlay picker, Spotify Connect, DLNA

# ─── Audio Output ─────────────────────────────────────────────────────────────
# Find your card with: aplay -l
# HDMI (default on Le Potato — Amlogic aml-augesound):
AUDIO_DEVICE=hw:0,0
# SPDIF optical (requires: sudo ldto merge spdif + reboot, set AIU SPDIF SRC SEL=I2S):
# AUDIO_DEVICE=hw:0,1
# USB DAC (plug in, verify card number with aplay -l):
# AUDIO_DEVICE=hw:1,0

# ─── Homelab / Navidrome ──────────────────────────────────────────────────────
# LAN IP: use http://192.168.x.x:4533
# Tailscale: use https://potatostack.tale-iwato.ts.net:4533
NAVIDROME_URL=http://192.168.1.100:4533
NAVIDROME_USER=daniel
NAVIDROME_PASS=changeme
SUBSONIC_ENABLE=yes

# ─── Tailscale ───────────────────────────────────────────────────────────────
# Generate at: https://login.tailscale.com/admin/settings/keys
# One-time auth key — used only on first start, then state is persisted in volume
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Snapcast (multi-room) ───────────────────────────────────────────────────
# IP of the homelab running snapcast server — use LAN IP for lowest latency
# Control music via: mpc -h HOMELAB_IP -p 6601 play
SNAPSERVER_HOST=192.168.1.100

# ─── Spotify ──────────────────────────────────────────────────────────────────
# spotifyd reads config/spotifyd.conf — set credentials there (not here)
# or set via keyring after first run

# ─── Timezone ────────────────────────────────────────────────────────────────
TZ=Europe/Berlin
